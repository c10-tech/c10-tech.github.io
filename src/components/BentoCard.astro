---
interface Props {
	title: string;
	span?: 1 | 2 | 3 | 4;
	rowSpan?: 1 | 2;
	ratio?: 'square' | 'wide';
	style?: string;
	img?: string;
	href?: string;
	date?: string;
}

const { title, span = 1, rowSpan = 1, ratio = 'square', style, img, href, date } = Astro.props;
---

<li
	class:list={['bento-card', `col-span-${span}`, `row-span-${rowSpan}`, `ratio-${ratio}`]}
	style={`${ratio === 'wide' ? 'aspect-ratio: 3 / 2;' : ''}${style ? ` ${style}` : ''}`}
>
	<a href={href} class="bento-link">
		{img && <img src={img} alt={title} loading="lazy" class="bento-bg" />}
		<div class="overlay"></div>
		{date && <div class="kicker">{date}</div>}
		<div class="content">
			<div class="header">
					{/** Shorten title to a concise word-level headline */}
					{(() => {
						const parts = String(title).split(/\s+/).filter(Boolean);
						const short = parts.slice(0, 3).join(' ');
						return (<h3 class="title" title={title}>{short}</h3>);
					})()}
			</div>
			<div class="footer">
				<slot />
			</div>
		</div>
	</a>
</li>

<style>
	.bento-card {
		position: relative;
		border-radius: 1.5rem;
		overflow: hidden;
		background: var(--gray-800);
		border: 1px solid var(--gray-800);
		aspect-ratio: 1 / 1;
		box-shadow: var(--shadow-sm);
		transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.2s ease;
		isolation: isolate;
	}

	.bento-card.ratio-wide {
		aspect-ratio: 3 / 2;
	}

	.bento-card:hover {
		transform: translateY(-4px) scale(1.01);
		box-shadow: var(--shadow-md);
		border-color: var(--accent-regular);
		z-index: 10;
	}

	/* Respect reduced-motion preference */
	@media (prefers-reduced-motion: reduce) {
		.bento-card,
		.bento-card:hover {
			transform: none;
			transition: none;
		}
	}

	.bento-card:hover .bento-bg {
		transform: scale(1.05);
	}

	.bento-link {
		display: block;
		width: 100%;
		height: 100%;
		text-decoration: none;
		color: var(--gray-200);
	}

	.bento-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 0;
		transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
	}

	.overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 55%, rgba(0,0,0,0) 100%);
		z-index: 1;
	}

	.kicker {
		position: absolute;
		top: 0.8rem;
		left: 0.8rem;
		z-index: 3;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--accent-light);
		background: rgba(0,0,0,0.25);
		padding: 0.25rem 0.5rem;
		border-radius: 0.5rem;
		border: 1px solid rgba(255,255,255,0.03);
	}

	.content {
		position: relative;
		z-index: 2;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 2rem;
	}

	.footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		color: var(--gray-200);
		font-size: 0.9rem;
		z-index: 3;
	}

	.header {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.date {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #ffffff;
		margin: 0;
		line-height: 1.1;
		text-shadow: 0 2px 4px rgba(0,0,0,0.5);
		/* Try to keep title to a single line when possible */
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		letter-spacing: -0.01em;
	}

	.footer {
		color: var(--gray-100);
		font-size: 1rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
	}

	/* Responsive grid spanning for desktop map to 4-col Grid */
	@media (min-width: 50em) {
		.col-span-1 { grid-column: span 1; }
		.col-span-2 { grid-column: span 2; aspect-ratio: 6 / 5; }
		.col-span-3 { grid-column: span 3; aspect-ratio: 6 / 5; }
		.col-span-4 { grid-column: span 4; aspect-ratio: 6 / 5; }
		
		.row-span-1 { grid-row: span 1; }
		.row-span-2 { grid-row: span 2; }
	}

/* On very small screens allow titles to wrap to avoid overflow */
@media (max-width: 420px) {
    .title { white-space: normal; }
}
</style>
